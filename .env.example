# --- Chạy local (uvicorn / npm) ---
# Backend: file .env trong backend/ hoặc export trước khi chạy uvicorn
DATABASE_URL=postgresql://shopee_user:shopee_pass@localhost:5432/shopee_db

# --- Docker Compose ---
# docker-compose.yml đã set DATABASE_URL=...@db:5432 cho service backend (không cần localhost).
# Tuỳ chọn: SECRET_KEY=... khi chạy: SECRET_KEY=xxx docker compose up --build
SECRET_KEY=thay-bang-chuoi-bi-mat-dai
SEED_ADMIN_EMAIL=admin@shopeeclone.dev
SEED_ADMIN_PASSWORD=admin123

# Frontend: tạo frontend/.env từ dòng sau
# VITE_API_URL=http://localhost:8000
